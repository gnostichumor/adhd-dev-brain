*.db
.beads-credential-key
.beads/proxieddb/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.python-version

# --- Test / lint / type-check artifacts ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/
.cache/

# --- Secrets & local env overrides ---
# config.yaml itself IS committed (secret fields ship blank per
# docs/architecture.md); only local overrides/real secrets are ignored.
.env
.env.*
!.env.example
*.local.yaml
*.secrets.yaml
secrets/
*.pem
*.key

# --- Node (in case any frontend tooling is added later) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Docker ---
*.pid

# --- Logs ---
*.log
logs/

# --- OS cruft ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Editors / IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Claude Code local overrides (never commit local-only permission tweaks) ---
.claude/settings.local.json

# --- Claude Code nested worktrees (EnterWorktree checks these out inside
# the repo's own working directory -- never part of any branch's tree) ---
.claude/worktrees/
